# Root .env for Docker Compose overrides
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=discord_scheduler

ACCESS_TOKEN_SECRET=change_me_super_secret_access_token_key_here
REFRESH_TOKEN_SECRET=change_me_super_secret_refresh_token_key_here

# Set to your VPS public IP or domain when deploying to a server
# Examples:
#   http://123.45.67.89:4000        (raw IP)
#   https://api.yourdomain.com      (domain with SSL)
NEXT_PUBLIC_API_URL=http://localhost:4000

